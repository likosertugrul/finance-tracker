{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@finance/core": ["packages/core/src"],
      "@finance/core/*": ["packages/core/src/*"],
      "@finance/data": ["packages/data/src"],
      "@finance/data/*": ["packages/data/src/*"],
      "@finance/ui": ["packages/ui/src"],
      "@finance/ui/*": ["packages/ui/src/*"],
      "@finance/state": ["packages/state/src"],
      "@finance/config": ["packages/config/src"],
      "@finance/types": ["packages/types/src"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
